{
  "title": "SRG Security Validation — srg-vulnerable-app",
  "description": "Disparado pelo GitHub Actions após cada deploy. Avalia o SRG Guardian e bloqueia se houver CVEs críticos.",
  "schemaVersion": 3,
  "trigger": {},
  "tasks": {
    "run_validation": {
      "name": "run_validation",
      "action": "dynatrace.site.reliability.guardian:validate-guardian-action",
      "active": true,
      "input": {
        "executableId": "GUARDIAN_ID_PLACEHOLDER",
        "executionRequestParameters": {
          "timeframeStart": "now()-1h",
          "timeframeEnd": "now()"
        }
      },
      "position": { "x": 0, "y": 1 },
      "conditions": {
        "states": {},
        "custom": "",
        "else": "STOP"
      },
      "timeout": 300000
    }
  }
}
