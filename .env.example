# Dynatrace OAuth2 Credentials
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git (it is in .gitignore).
#
# Create an OAuth client at:
#   https://fov31014.apps.dynatrace.com/ui/apps/dynatrace.classic.settings/settings/oauth-client-management
#
# Required OAuth scopes:
#   automation:workflows:read
#   automation:workflows:write
#   automation:workflows:run
#   srg:guardians:read
#   srg:guardians:write
#   security:findings:read
#   openpipeline:events:ingest
# ─────────────────────────────────────────────────────────────────────────────

DT_CLIENT_ID=dt0s02.XXXXXXXXXXXXXXXXXXXXXXXXXX
DT_CLIENT_SECRET=dt0s02.XXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DT_TENANT_URL=https://fov31014.apps.dynatrace.com

# Populated by scripts/setup_dynatrace.sh
DT_WORKFLOW_ID=
DT_GUARDIAN_ID=

# App settings
APP_VERSION=1.0.0
STAGE=production
BUILD_NUMBER=1

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
