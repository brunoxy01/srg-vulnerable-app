<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search — XSS Demo</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container py-5" style="max-width: 600px;">
    <a href="/" class="btn btn-sm btn-outline-secondary mb-3">← Back</a>

    <div class="card shadow-sm">
      <div class="card-header bg-warning">
        <h5 class="mb-0">⚠️ Reflected XSS Demo — Search</h5>
      </div>
      <div class="card-body">

        <div class="alert alert-warning small mb-4">
          <strong>Vulnerability:</strong> Reflected XSS<br>
          <strong>PoC:</strong> <code>/search?q=&lt;script&gt;alert(document.cookie)&lt;/script&gt;</code>
        </div>

        <form method="GET" action="/search">
          <div class="input-group mb-3">
            <input type="text" name="q" class="form-control"
                   value="<%= query %>" placeholder="Search anything...">
            <button class="btn btn-warning" type="submit">Search</button>
          </div>
        </form>

        <% if (query) { %>
          <div class="mt-3 p-3 border rounded bg-white">
            <!-- ❌ INTENTIONAL XSS: <%-  outputs raw unescaped HTML -->
            <p class="mb-1">Results for: <strong><%- query %></strong></p>
            <p class="text-muted small mb-0">No matching records found.</p>
          </div>
        <% } %>

      </div>
    </div>
  </div>
</body>
</html>
